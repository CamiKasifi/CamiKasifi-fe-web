# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Supabase Project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anon (public) key — Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudflare Turnstile site key — imam self-kayıt formundaki captcha için.
# Turnstile dashboard'da bir site oluştur; site key buraya, secret key ise
# Supabase → Authentication → Bot & Abuse Protection → CAPTCHA (Turnstile)
# altına girilir. Boş bırakılırsa kayıt formu captcha'sız çalışır (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
